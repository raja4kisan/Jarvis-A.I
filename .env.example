# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# YouTube Data API (Get from: https://console.cloud.google.com/)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Weather API (Get from: https://www.weatherapi.com/)
WEATHER_API_KEY=your_weather_api_key_here

# News API (Get from: https://newsdata.io/)
NEWS_API_KEY=your_news_api_key_here

# DeepSeek API (Optional - Get from: https://platform.deepseek.com/)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenRouter API (Optional - Get from: https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Cricket Data API (Optional - Get from: https://cricketdata.org/)
CRICKET_API_KEY=your_cricket_api_key_here
